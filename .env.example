# Vortex Analytics - Gemini API Configuration
# Replace YOUR_API_KEY_HERE with your key from https://aistudio.google.com/app/apikey
NEXT_PUBLIC_GEMINI_KEY=YOUR_GEMINI_API_KEY_HERE

# Database Mode
# Options: 'CSV' or 'SUPABASE'
DATA_SOURCE=CSV

# Cloud Credentials (Supabase)
# Required only if DATA_SOURCE is set to 'SUPABASE'
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL_HERE
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY_HERE
